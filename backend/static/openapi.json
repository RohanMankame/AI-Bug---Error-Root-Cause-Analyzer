{
  "openapi": "3.0.3",
  "info": {
    "title": "AI Bug & Error Root Cause Analyzer",
    "version": "1.0.0",
    "description": "API for analyzing error messages and reporting possible root causes."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/supported-languages": {
      "get": {
        "summary": "Get supported languages",
        "responses": {
          "200": {
            "description": "List of supported languages.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SupportedLanguagesResponse"
                }
              }
            }
          }
        }
      }
    },

"/api/reevaluate": {
  "post": {
    "summary": "Re-evaluate the error analysis with user feedback",
    "requestBody": {
      "required": true,
      "content": {
        "application/json": {
          "schema": {
            "type": "object",
            "properties": {
              "error_input": { "type": "string" },
              "metadata": {
                "type": "object",
                "properties": {
                  "detected_language": { "type": "string" },
                  "language_confidence": { "type": "number" },
                  "detected_platform": { "type": ["string", "null"] },
                  "severity": { "type": "string" },
                  "error_type": { "type": "string" },
                  "error_message": { "type": "string" }
                },
                "required": [
                  "detected_language",
                  "language_confidence",
                  "detected_platform",
                  "severity",
                  "error_type",
                  "error_message"
                ]
              },
              "analysis": {
                "type": "object",
                "properties": {
                  "root_cause": { "type": "string" },
                  "recommendations": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "preventive_suggestions": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "required": [
                  "root_cause",
                  "recommendations",
                  "preventive_suggestions"
                ]
              },
              "user_message": { "type": "string" }
            },
            "required": ["error_input", "metadata", "analysis", "user_message"]
          },
          "example": {
            "error_input": "Traceback (most recent call last): ...",
            "metadata": {
              "detected_language": "python",
              "language_confidence": 0.9,
              "detected_platform": null,
              "severity": "high",
              "error_type": "dependency_error",
              "error_message": "ModuleNotFoundError: No module named 'pandas'"
            },
            "analysis": {
              "root_cause": "The module 'pandas' is not installed.",
              "recommendations": ["Run 'pip install pandas'."],
              "preventive_suggestions": ["Add 'pandas' to your requirements.txt."]
            },
            "user_message": "I tried installing pandas, but now I get a DLL load failed error. Can you help me fix this new issue?"
          }
        }
      }
    },
    "responses": {
      "200": {
        "description": "Re-evaluated analysis with updated metadata and analysis",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "error_input": { "type": "string" },
                "metadata": {
                  "type": "object",
                  "properties": {
                    "detected_language": { "type": "string" },
                    "language_confidence": { "type": "number" },
                    "detected_platform": { "type": ["string", "null"] },
                    "severity": { "type": "string" },
                    "error_type": { "type": "string" },
                    "error_message": { "type": "string" }
                  }
                },
                "analysis": {
                  "type": "object",
                  "properties": {
                    "root_cause": { "type": "string" },
                    "recommendations": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "preventive_suggestions": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              },
              "required": ["error_input", "metadata", "analysis"]
            }
          }
        }
      },
      "400": { "description": "Invalid input" },
      "500": { "description": "Server error" }
    }
  }
} ,

    "/api/analyze": {
      "post": {
        "summary": "Analyze an error message or stack trace",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AnalyzeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Analysis result.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyzeResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnalyzeRequest": {
        "type": "object",
        "required": ["error_input"],
        "properties": {
          "error_input": {
            "type": "string",
            "description": "Error message or stack trace."
          }
        },
        "additionalProperties": false
      },
      "AnalyzeResponse": {
        "type": "object",
        "properties": {
          "metadata": {
            "type": "object",
            "additionalProperties": true
          },
          "analysis": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "example": "healthy"
          }
        },
        "additionalProperties": false
      },
      "SupportedLanguagesResponse": {
        "type": "object",
        "properties": {
          "languages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  }
}